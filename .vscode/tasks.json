{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe build active file",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/Fe${fileDirname}\\${fileBasenameNoExtension}.exe",
                "${workspaceFolder}\\src\\*.cpp",
                "/IC:\\Program Files\\MySQL\\mysql-connector-cpp-9.7.0\\include",
                "/link",
                "/LIBPATH:C:\\Program Files\\MySQL\\mysql-connector-cpp-9.7.0\\lib64\\vs14",
                "mysqlcppconn.lib"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$msCompile"],
            "group": { "kind": "build", "isDefault": true }
        }
    ]
}